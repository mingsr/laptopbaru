<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NABUNG UNTUK MASA DEPAN</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@400;500;600;700&family=Orbitron:wght@400;700;900&display=swap" rel="stylesheet">

<style>
/* ============================================================
   DESIGN TOKENS — Cyberpunk / Neon Theme
   ============================================================ */
:root {
  --clr-bg:        #080b14;
  --clr-bg2:       #0d1323;
  --clr-bg3:       #111827;
  --clr-panel:     #0f1729;
  --clr-border:    #1a2644;
  --clr-blue:      #00d4ff;
  --clr-blue-dim:  #0090bb;
  --clr-purple:    #bf00ff;
  --clr-purple-dim:#7d00aa;
  --clr-pink:      #ff00c8;
  --clr-green:     #00ff88;
  --clr-yellow:    #ffe600;
  --clr-red:       #ff3060;
  --clr-text:      #c8d8f0;
  --clr-text-dim:  #6278a0;
  --clr-text-muted:#3a4a70;

  --ff-display: 'Orbitron', monospace;
  --ff-body:    'Rajdhani', sans-serif;
  --ff-mono:    'Share Tech Mono', monospace;

  --radius:  6px;
  --radius-lg: 12px;

  --glow-blue:   0 0 10px #00d4ff44, 0 0 30px #00d4ff22;
  --glow-purple: 0 0 10px #bf00ff44, 0 0 30px #bf00ff22;
  --glow-pink:   0 0 10px #ff00c844, 0 0 30px #ff00c822;
  --glow-green:  0 0 10px #00ff8844, 0 0 30px #00ff8822;

  --transition: 0.2s ease;
}

/* ============================================================
   RESET & BASE
   ============================================================ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  background: var(--clr-bg);
  color: var(--clr-text);
  font-family: var(--ff-body);
  font-size: 16px;
  line-height: 1.6;
  min-height: 100vh;
  overflow-x: hidden;
}

/* Scanline overlay */
body::after {
  content: '';
  position: fixed;
  inset: 0;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 2px,
    rgba(0,0,0,0.03) 2px,
    rgba(0,0,0,0.03) 4px
  );
  pointer-events: none;
  z-index: 9999;
}

::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: var(--clr-bg2); }
::-webkit-scrollbar-thumb { background: var(--clr-blue-dim); border-radius: 3px; }

/* ============================================================
   UTILITY
   ============================================================ */
.hidden { display: none !important; }
.text-blue   { color: var(--clr-blue); }
.text-purple { color: var(--clr-purple); }
.text-green  { color: var(--clr-green); }
.text-red    { color: var(--clr-red); }
.text-yellow { color: var(--clr-yellow); }
.text-dim    { color: var(--clr-text-dim); }
.font-mono   { font-family: var(--ff-mono); }
.font-display { font-family: var(--ff-display); }

/* ============================================================
   GRID NOISE BACKGROUND
   ============================================================ */
.grid-bg {
  position: fixed;
  inset: 0;
  background-image:
    linear-gradient(rgba(0,212,255,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,212,255,0.03) 1px, transparent 1px);
  background-size: 40px 40px;
  pointer-events: none;
  z-index: 0;
}

/* ============================================================
   LOGIN SCREEN
   ============================================================ */
#screen-login {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  position: relative;
  z-index: 1;
}

.login-card {
  width: 100%;
  max-width: 420px;
  padding: 48px 40px;
  background: var(--clr-panel);
  border: 1px solid var(--clr-blue-dim);
  border-radius: var(--radius-lg);
  box-shadow: var(--glow-blue), inset 0 0 40px rgba(0,212,255,0.03);
  position: relative;
  overflow: hidden;
}

.login-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--clr-blue), var(--clr-purple), transparent);
}

.login-logo {
  text-align: center;
  margin-bottom: 32px;
}

.login-logo .logo-icon {
  font-size: 48px;
  display: block;
  margin-bottom: 12px;
  filter: drop-shadow(0 0 16px var(--clr-blue));
  animation: pulse-icon 3s ease-in-out infinite;
}

@keyframes pulse-icon {
  0%, 100% { filter: drop-shadow(0 0 16px var(--clr-blue)); }
  50%       { filter: drop-shadow(0 0 28px var(--clr-purple)); }
}

.login-logo h1 {
  font-family: var(--ff-display);
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 0.25em;
  color: var(--clr-blue);
  text-shadow: var(--glow-blue);
  line-height: 1.4;
}

.login-logo p {
  font-size: 12px;
  color: var(--clr-text-dim);
  letter-spacing: 0.1em;
  margin-top: 4px;
  font-family: var(--ff-mono);
}

.form-group { margin-bottom: 20px; }

.form-label {
  display: block;
  font-size: 11px;
  font-family: var(--ff-mono);
  color: var(--clr-blue);
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-bottom: 8px;
}

.form-input {
  width: 100%;
  padding: 12px 16px;
  background: var(--clr-bg2);
  border: 1px solid var(--clr-border);
  border-radius: var(--radius);
  color: var(--clr-text);
  font-family: var(--ff-mono);
  font-size: 14px;
  outline: none;
  transition: border-color var(--transition), box-shadow var(--transition);
}

.form-input:focus {
  border-color: var(--clr-blue);
  box-shadow: 0 0 0 2px rgba(0,212,255,0.15);
}

.form-input::placeholder { color: var(--clr-text-muted); }

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 12px 24px;
  border: none;
  border-radius: var(--radius);
  font-family: var(--ff-display);
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.1em;
  cursor: pointer;
  transition: all var(--transition);
  text-decoration: none;
  white-space: nowrap;
}

.btn-primary {
  width: 100%;
  background: linear-gradient(135deg, var(--clr-blue), var(--clr-purple));
  color: #fff;
  box-shadow: var(--glow-blue);
}

.btn-primary:hover {
  transform: translateY(-1px);
  box-shadow: 0 0 20px rgba(0,212,255,0.5), 0 0 40px rgba(191,0,255,0.3);
}

.btn-primary:active { transform: translateY(0); }

.btn-ghost {
  background: transparent;
  border: 1px solid var(--clr-border);
  color: var(--clr-text-dim);
}

.btn-ghost:hover {
  border-color: var(--clr-blue);
  color: var(--clr-blue);
}

.btn-danger {
  background: transparent;
  border: 1px solid var(--clr-red);
  color: var(--clr-red);
}
.btn-danger:hover { background: rgba(255,48,96,0.1); }

.btn-sm { padding: 7px 14px; font-size: 11px; }

.error-msg {
  background: rgba(255,48,96,0.1);
  border: 1px solid var(--clr-red);
  border-radius: var(--radius);
  padding: 10px 14px;
  font-size: 13px;
  color: var(--clr-red);
  margin-top: 16px;
  font-family: var(--ff-mono);
  display: none;
}

/* ============================================================
   APP LAYOUT
   ============================================================ */
#screen-app {
  display: none;
  min-height: 100vh;
  position: relative;
  z-index: 1;
}

/* Top Nav */
.topnav {
  position: fixed;
  top: 0; left: 0; right: 0;
  height: 60px;
  background: rgba(8,11,20,0.92);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--clr-border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24px;
  z-index: 100;
}

.topnav-brand {
  font-family: var(--ff-display);
  font-size: 13px;
  font-weight: 700;
  color: var(--clr-blue);
  letter-spacing: 0.12em;
  text-shadow: var(--glow-blue);
  display: flex;
  align-items: center;
  gap: 10px;
}

.topnav-brand span { font-size: 18px; }

.topnav-right { display: flex; align-items: center; gap: 12px; }

.level-badge {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 4px 12px;
  background: var(--clr-bg2);
  border: 1px solid var(--clr-purple-dim);
  border-radius: 99px;
  font-size: 12px;
  font-family: var(--ff-mono);
  color: var(--clr-purple);
}

/* Sidebar Nav */
.sidebar {
  position: fixed;
  top: 60px; bottom: 0; left: 0;
  width: 220px;
  background: var(--clr-bg2);
  border-right: 1px solid var(--clr-border);
  padding: 24px 0;
  z-index: 90;
  overflow-y: auto;
  transition: transform var(--transition);
}

.nav-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 24px;
  color: var(--clr-text-dim);
  font-family: var(--ff-body);
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 0.05em;
  cursor: pointer;
  transition: all var(--transition);
  border-left: 3px solid transparent;
  user-select: none;
}

.nav-item:hover {
  color: var(--clr-text);
  background: rgba(0,212,255,0.05);
  border-left-color: var(--clr-blue-dim);
}

.nav-item.active {
  color: var(--clr-blue);
  background: rgba(0,212,255,0.08);
  border-left-color: var(--clr-blue);
}

.nav-item .nav-icon { font-size: 18px; width: 22px; text-align: center; }

.nav-section-label {
  padding: 16px 24px 6px;
  font-size: 10px;
  font-family: var(--ff-mono);
  color: var(--clr-text-muted);
  letter-spacing: 0.2em;
  text-transform: uppercase;
}

/* Main Content */
.main-content {
  margin-left: 220px;
  margin-top: 60px;
  padding: 28px;
  min-height: calc(100vh - 60px);
}

/* Hamburger */
.hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  cursor: pointer;
  padding: 6px;
  background: none;
  border: none;
}

.hamburger span {
  display: block;
  width: 22px;
  height: 2px;
  background: var(--clr-blue);
  border-radius: 2px;
  transition: all 0.3s;
}

/* ============================================================
   PAGE VIEWS
   ============================================================ */
.page-view { display: none; }
.page-view.active { display: block; }

.page-header {
  margin-bottom: 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 12px;
}

.page-title {
  font-family: var(--ff-display);
  font-size: 20px;
  font-weight: 700;
  color: var(--clr-blue);
  text-shadow: var(--glow-blue);
  letter-spacing: 0.08em;
}

.page-subtitle {
  font-size: 13px;
  color: var(--clr-text-dim);
  font-family: var(--ff-mono);
  margin-top: 2px;
}

/* ============================================================
   CARDS & PANELS
   ============================================================ */
.card {
  background: var(--clr-panel);
  border: 1px solid var(--clr-border);
  border-radius: var(--radius-lg);
  padding: 24px;
  position: relative;
  overflow: hidden;
}

.card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent 10%, var(--clr-blue-dim) 50%, transparent 90%);
  opacity: 0.5;
}

.card-title {
  font-family: var(--ff-display);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.2em;
  color: var(--clr-text-dim);
  text-transform: uppercase;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 8px;
}

/* ============================================================
   DASHBOARD GRID
   ============================================================ */
.dashboard-grid {
  display: grid;
  grid-template-columns: repeat(12, 1fr);
  gap: 20px;
}

.col-12 { grid-column: span 12; }
.col-8  { grid-column: span 8; }
.col-4  { grid-column: span 4; }
.col-6  { grid-column: span 6; }
.col-3  { grid-column: span 3; }

/* ============================================================
   HERO TARGET CARD
   ============================================================ */
.hero-target {
  background: linear-gradient(135deg, rgba(0,212,255,0.05) 0%, rgba(191,0,255,0.05) 100%);
  border-color: var(--clr-blue-dim);
  box-shadow: var(--glow-blue);
}

.target-name {
  font-family: var(--ff-display);
  font-size: 22px;
  font-weight: 900;
  color: #fff;
  margin-bottom: 4px;
  letter-spacing: 0.05em;
}

.target-amount {
  font-family: var(--ff-mono);
  font-size: 36px;
  color: var(--clr-blue);
  text-shadow: var(--glow-blue);
  line-height: 1;
  margin: 12px 0;
}

.target-amount small {
  font-size: 14px;
  color: var(--clr-text-dim);
}

.target-meta-row {
  display: flex;
  gap: 24px;
  margin-bottom: 20px;
  flex-wrap: wrap;
}

.target-meta-item { }
.target-meta-item .label {
  font-size: 11px;
  color: var(--clr-text-muted);
  font-family: var(--ff-mono);
  letter-spacing: 0.1em;
}
.target-meta-item .value {
  font-size: 16px;
  font-family: var(--ff-mono);
  color: var(--clr-text);
  font-weight: bold;
}

/* Progress Bar */
.progress-wrap {
  margin-bottom: 8px;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
  font-size: 12px;
  font-family: var(--ff-mono);
}

.progress-bar-track {
  width: 100%;
  height: 12px;
  background: var(--clr-bg2);
  border-radius: 99px;
  overflow: hidden;
  position: relative;
  border: 1px solid var(--clr-border);
}

.progress-bar-fill {
  height: 100%;
  border-radius: 99px;
  background: linear-gradient(90deg, var(--clr-blue), var(--clr-purple), var(--clr-pink));
  transition: width 1s ease;
  position: relative;
  box-shadow: 0 0 12px rgba(0,212,255,0.6);
}

.progress-bar-fill::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(90deg, transparent 60%, rgba(255,255,255,0.2));
  border-radius: 99px;
}

/* ============================================================
   STAT CARDS
   ============================================================ */
.stat-card {
  text-align: center;
}

.stat-card .stat-icon {
  font-size: 28px;
  margin-bottom: 8px;
  display: block;
}

.stat-card .stat-value {
  font-family: var(--ff-mono);
  font-size: 22px;
  font-weight: bold;
  line-height: 1;
  margin-bottom: 4px;
}

.stat-card .stat-label {
  font-size: 11px;
  color: var(--clr-text-dim);
  font-family: var(--ff-mono);
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

/* Color variants */
.card-blue  { border-color: rgba(0,212,255,0.3);   }
.card-blue .stat-value  { color: var(--clr-blue);   text-shadow: var(--glow-blue);   }
.card-purple { border-color: rgba(191,0,255,0.3);  }
.card-purple .stat-value { color: var(--clr-purple); text-shadow: var(--glow-purple); }
.card-green { border-color: rgba(0,255,136,0.3);   }
.card-green .stat-value  { color: var(--clr-green);  text-shadow: var(--glow-green);  }
.card-pink  { border-color: rgba(255,0,200,0.3);   }
.card-pink .stat-value   { color: var(--clr-pink);   text-shadow: var(--glow-pink);   }

/* ============================================================
   QUOTE CARD
   ============================================================ */
.quote-card {
  background: linear-gradient(135deg, rgba(191,0,255,0.05), rgba(0,212,255,0.05));
  border-color: rgba(191,0,255,0.3);
}

.quote-text {
  font-size: 16px;
  font-style: italic;
  color: var(--clr-text);
  line-height: 1.7;
  position: relative;
  padding-left: 24px;
}

.quote-text::before {
  content: '"';
  position: absolute;
  left: 0;
  top: -4px;
  font-size: 48px;
  color: var(--clr-purple);
  opacity: 0.5;
  font-family: Georgia, serif;
  line-height: 1;
}

.quote-author {
  margin-top: 10px;
  font-size: 12px;
  font-family: var(--ff-mono);
  color: var(--clr-purple);
  padding-left: 24px;
}

/* ============================================================
   STREAK / MINI STATS
   ============================================================ */
.streak-display {
  display: flex;
  align-items: center;
  gap: 12px;
}

.streak-fire {
  font-size: 40px;
  animation: flicker 2s ease-in-out infinite alternate;
}

@keyframes flicker {
  0%   { filter: drop-shadow(0 0 8px #ff6600); }
  50%  { filter: drop-shadow(0 0 20px #ff9900); }
  100% { filter: drop-shadow(0 0 8px #ff3300); }
}

.streak-number {
  font-family: var(--ff-display);
  font-size: 48px;
  font-weight: 900;
  color: var(--clr-yellow);
  text-shadow: 0 0 20px rgba(255,230,0,0.5);
  line-height: 1;
}

/* ============================================================
   MINI CHART (SVG-based)
   ============================================================ */
.chart-wrap {
  overflow: hidden;
}

.chart-svg {
  width: 100%;
  height: 120px;
}

/* ============================================================
   SAVING CALENDAR
   ============================================================ */
.calendar-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 3px;
  margin-top: 8px;
}

.cal-dot {
  width: 12px;
  height: 12px;
  border-radius: 2px;
  background: var(--clr-bg2);
  border: 1px solid var(--clr-border);
  transition: all 0.2s;
}

.cal-dot.has-saving {
  background: var(--clr-blue);
  border-color: var(--clr-blue);
  box-shadow: 0 0 4px rgba(0,212,255,0.5);
}

.cal-dot.today {
  border-color: var(--clr-yellow);
}

/* ============================================================
   LEVEL BAR
   ============================================================ */
.level-info {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 12px;
}

.level-icon-big { font-size: 36px; }

.level-name {
  font-family: var(--ff-display);
  font-size: 16px;
  color: var(--clr-purple);
  text-shadow: var(--glow-purple);
}

.level-num {
  font-family: var(--ff-mono);
  font-size: 12px;
  color: var(--clr-text-dim);
}

/* ============================================================
   TRANSACTIONS PAGE
   ============================================================ */
.filters-row {
  display: flex;
  gap: 12px;
  margin-bottom: 20px;
  flex-wrap: wrap;
  align-items: flex-end;
}

.filter-group { display: flex; flex-direction: column; gap: 4px; }
.filter-label {
  font-size: 10px;
  font-family: var(--ff-mono);
  color: var(--clr-text-dim);
  letter-spacing: 0.1em;
}

.filter-select, .filter-input {
  padding: 8px 12px;
  background: var(--clr-bg2);
  border: 1px solid var(--clr-border);
  border-radius: var(--radius);
  color: var(--clr-text);
  font-family: var(--ff-mono);
  font-size: 13px;
  outline: none;
  cursor: pointer;
}

.filter-select:focus, .filter-input:focus {
  border-color: var(--clr-blue);
}

.filter-select option { background: var(--clr-bg2); }

/* Transaction table */
.tx-table-wrap {
  overflow-x: auto;
}

.tx-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
}

.tx-table th {
  font-family: var(--ff-mono);
  font-size: 10px;
  letter-spacing: 0.15em;
  color: var(--clr-text-dim);
  text-transform: uppercase;
  padding: 10px 16px;
  text-align: left;
  border-bottom: 1px solid var(--clr-border);
  white-space: nowrap;
}

.tx-table td {
  padding: 12px 16px;
  border-bottom: 1px solid rgba(26,38,68,0.5);
  vertical-align: middle;
}

.tx-table tr:hover td {
  background: rgba(0,212,255,0.03);
}

.tx-type-badge {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 4px;
  font-family: var(--ff-mono);
  font-size: 10px;
  font-weight: bold;
  letter-spacing: 0.1em;
}

.badge-INCOME     { background: rgba(0,255,136,0.15); color: var(--clr-green); border: 1px solid rgba(0,255,136,0.3); }
.badge-EXPENSE    { background: rgba(255,48,96,0.15);  color: var(--clr-red);   border: 1px solid rgba(255,48,96,0.3); }
.badge-SAVING     { background: rgba(0,212,255,0.15);  color: var(--clr-blue);  border: 1px solid rgba(0,212,255,0.3); }
.badge-WITHDRAWAL { background: rgba(255,230,0,0.15);  color: var(--clr-yellow);border: 1px solid rgba(255,230,0,0.3); }

.tx-nominal-positive { color: var(--clr-green); font-family: var(--ff-mono); }
.tx-nominal-negative { color: var(--clr-red); font-family: var(--ff-mono); }
.tx-nominal-saving   { color: var(--clr-blue); font-family: var(--ff-mono); }
.tx-nominal-withdraw { color: var(--clr-yellow); font-family: var(--ff-mono); }

.tx-action-btn {
  background: none;
  border: none;
  cursor: pointer;
  color: var(--clr-text-dim);
  font-size: 14px;
  padding: 4px;
  transition: color var(--transition);
}
.tx-action-btn:hover { color: var(--clr-blue); }
.tx-action-btn.del:hover { color: var(--clr-red); }

.pagination {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16px;
  font-size: 13px;
  font-family: var(--ff-mono);
  color: var(--clr-text-dim);
  flex-wrap: wrap;
  gap: 8px;
}

.pagination-btns { display: flex; gap: 8px; }

/* Empty state */
.empty-state {
  text-align: center;
  padding: 48px 24px;
  color: var(--clr-text-muted);
}
.empty-state .empty-icon { font-size: 48px; margin-bottom: 12px; opacity: 0.5; }
.empty-state p { font-family: var(--ff-mono); font-size: 13px; }

/* ============================================================
   MODAL
   ============================================================ */
.modal-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(8,11,20,0.85);
  backdrop-filter: blur(4px);
  z-index: 200;
  align-items: center;
  justify-content: center;
  padding: 20px;
}

.modal-overlay.open { display: flex; }

.modal-box {
  background: var(--clr-panel);
  border: 1px solid var(--clr-blue-dim);
  border-radius: var(--radius-lg);
  width: 100%;
  max-width: 480px;
  max-height: 90vh;
  overflow-y: auto;
  box-shadow: var(--glow-blue);
  position: relative;
}

.modal-box::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--clr-blue), var(--clr-purple), transparent);
}

.modal-header {
  padding: 24px 24px 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1px solid var(--clr-border);
}

.modal-title {
  font-family: var(--ff-display);
  font-size: 14px;
  color: var(--clr-blue);
  letter-spacing: 0.1em;
}

.modal-close {
  background: none;
  border: none;
  color: var(--clr-text-dim);
  font-size: 20px;
  cursor: pointer;
  padding: 4px;
  line-height: 1;
  transition: color var(--transition);
}
.modal-close:hover { color: var(--clr-red); }

.modal-body { padding: 24px; }

.modal-footer {
  padding: 16px 24px;
  border-top: 1px solid var(--clr-border);
  display: flex;
  gap: 12px;
  justify-content: flex-end;
}

/* Form row */
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

/* ============================================================
   ACHIEVEMENTS PAGE
   ============================================================ */
.achievements-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 16px;
}

.achievement-card {
  background: var(--clr-panel);
  border: 1px solid var(--clr-border);
  border-radius: var(--radius-lg);
  padding: 20px;
  display: flex;
  gap: 16px;
  align-items: flex-start;
  transition: all var(--transition);
  position: relative;
  overflow: hidden;
}

.achievement-card.unlocked {
  border-color: rgba(0,212,255,0.3);
  box-shadow: 0 0 12px rgba(0,212,255,0.1);
}

.achievement-card.unlocked::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--clr-blue), transparent);
}

.achievement-card.locked { opacity: 0.5; }

.ach-icon { font-size: 32px; flex-shrink: 0; line-height: 1; }
.ach-name {
  font-family: var(--ff-display);
  font-size: 13px;
  color: var(--clr-text);
  margin-bottom: 4px;
}
.ach-desc { font-size: 12px; color: var(--clr-text-dim); line-height: 1.5; }
.ach-date { font-size: 11px; font-family: var(--ff-mono); color: var(--clr-blue); margin-top: 6px; }

/* Unlock animation */
@keyframes unlock-pop {
  0%   { transform: scale(0.5); opacity: 0; }
  70%  { transform: scale(1.1); }
  100% { transform: scale(1); opacity: 1; }
}

/* ============================================================
   TARGET PAGE
   ============================================================ */
.target-form-card {
  max-width: 560px;
}

/* ============================================================
   HALL OF FAME
   ============================================================ */
.hof-list { display: flex; flex-direction: column; gap: 12px; }

.hof-item {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 16px 20px;
  background: var(--clr-bg2);
  border: 1px solid var(--clr-border);
  border-radius: var(--radius);
}

.hof-rank {
  font-family: var(--ff-display);
  font-size: 24px;
  font-weight: 900;
  color: var(--clr-yellow);
  opacity: 0.7;
  width: 36px;
  text-align: center;
}

.hof-info { flex: 1; }
.hof-name { font-weight: 700; font-size: 15px; margin-bottom: 2px; }
.hof-meta { font-size: 12px; font-family: var(--ff-mono); color: var(--clr-text-dim); }

.hof-amount {
  font-family: var(--ff-mono);
  font-size: 16px;
  color: var(--clr-green);
  text-align: right;
}

/* ============================================================
   TOAST NOTIFICATION
   ============================================================ */
.toast-container {
  position: fixed;
  top: 80px; right: 20px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  z-index: 999;
  pointer-events: none;
}

.toast {
  background: var(--clr-panel);
  border: 1px solid var(--clr-blue-dim);
  border-radius: var(--radius);
  padding: 14px 18px;
  min-width: 280px;
  max-width: 340px;
  display: flex;
  align-items: flex-start;
  gap: 12px;
  box-shadow: var(--glow-blue);
  animation: toast-in 0.3s ease;
  pointer-events: all;
}

@keyframes toast-in {
  from { transform: translateX(100%); opacity: 0; }
  to   { transform: translateX(0);    opacity: 1; }
}

.toast.out { animation: toast-out 0.3s ease forwards; }

@keyframes toast-out {
  from { transform: translateX(0);    opacity: 1; }
  to   { transform: translateX(100%); opacity: 0; }
}

.toast-icon { font-size: 20px; flex-shrink: 0; margin-top: 1px; }
.toast-content { flex: 1; }
.toast-title { font-weight: 700; font-size: 13px; font-family: var(--ff-display); letter-spacing: 0.05em; margin-bottom: 2px; }
.toast-msg   { font-size: 12px; color: var(--clr-text-dim); }

.toast-success { border-color: rgba(0,255,136,0.5); }
.toast-success .toast-title { color: var(--clr-green); }
.toast-error   { border-color: rgba(255,48,96,0.5); }
.toast-error .toast-title   { color: var(--clr-red); }
.toast-achievement {
  border-color: rgba(191,0,255,0.5);
  background: linear-gradient(135deg, rgba(191,0,255,0.1), rgba(0,212,255,0.05));
  box-shadow: var(--glow-purple);
}
.toast-achievement .toast-title { color: var(--clr-purple); }

/* ============================================================
   LOADING STATE
   ============================================================ */
.spinner {
  width: 24px; height: 24px;
  border: 2px solid var(--clr-border);
  border-top-color: var(--clr-blue);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  display: inline-block;
}

@keyframes spin { to { transform: rotate(360deg); } }

.loading-center {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 200px;
  gap: 12px;
  color: var(--clr-text-dim);
  font-family: var(--ff-mono);
  font-size: 13px;
}

/* ============================================================
   PREDICTION CHIP
   ============================================================ */
.prediction-chip {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 4px 12px;
  background: rgba(0,255,136,0.1);
  border: 1px solid rgba(0,255,136,0.3);
  border-radius: 99px;
  font-size: 12px;
  font-family: var(--ff-mono);
  color: var(--clr-green);
}

/* ============================================================
   SIDEBAR OVERLAY (mobile)
   ============================================================ */
.sidebar-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.6);
  z-index: 89;
}

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media (max-width: 1024px) {
  .col-8  { grid-column: span 12; }
  .col-4  { grid-column: span 12; }
  .col-3  { grid-column: span 6; }
  .col-6  { grid-column: span 12; }
}

@media (max-width: 768px) {
  .sidebar {
    transform: translateX(-100%);
    width: 240px;
  }
  .sidebar.open {
    transform: translateX(0);
    box-shadow: 4px 0 24px rgba(0,0,0,0.5);
  }
  .sidebar-overlay.visible { display: block; }
  .hamburger { display: flex; }
  .main-content { margin-left: 0; padding: 16px; }
  .col-3  { grid-column: span 6; }
  .col-6  { grid-column: span 12; }
  .dashboard-grid { gap: 14px; }
  .target-amount { font-size: 26px; }
  .form-row { grid-template-columns: 1fr; }
  .filters-row { gap: 8px; }
}

@media (max-width: 480px) {
  .col-3 { grid-column: span 12; }
  .topnav { padding: 0 16px; }
  .topnav-brand { font-size: 11px; }
  .level-badge { display: none; }
}

/* ============================================================
   CHANGE PASSWORD FORM
   ============================================================ */
.settings-section {
  max-width: 480px;
}

/* Scrollbar in modals */
.modal-box::-webkit-scrollbar { width: 4px; }
.modal-box::-webkit-scrollbar-thumb { background: var(--clr-blue-dim); }

/* ============================================================
   DELETE CONFIRM MODAL
   ============================================================ */
.confirm-icon { font-size: 48px; text-align: center; margin-bottom: 12px; }
.confirm-text { text-align: center; color: var(--clr-text); line-height: 1.6; }

/* ============================================================
   COMPLETE TARGET MODAL
   ============================================================ */
.complete-celebration {
  text-align: center;
  padding: 8px 0 16px;
}
.complete-celebration .big-emoji {
  font-size: 64px;
  display: block;
  animation: unlock-pop 0.5s ease;
}
.complete-celebration h3 {
  font-family: var(--ff-display);
  font-size: 18px;
  color: var(--clr-blue);
  text-shadow: var(--glow-blue);
  margin: 12px 0 8px;
}
.complete-celebration p {
  color: var(--clr-text-dim);
  font-size: 14px;
}

/* segment buttons */
.seg-btns {
  display: flex;
  gap: 4px;
  padding: 4px;
  background: var(--clr-bg2);
  border-radius: var(--radius);
  border: 1px solid var(--clr-border);
  width: fit-content;
}

.seg-btn {
  padding: 6px 16px;
  border-radius: 4px;
  font-family: var(--ff-mono);
  font-size: 12px;
  cursor: pointer;
  border: none;
  background: transparent;
  color: var(--clr-text-dim);
  transition: all 0.2s;
}

.seg-btn.active {
  background: linear-gradient(135deg, var(--clr-blue), var(--clr-purple));
  color: #fff;
}

/* ============================================================
   MINI LINE CHART
   ============================================================ */
.chart-legend {
  display: flex;
  gap: 16px;
  margin-top: 8px;
  flex-wrap: wrap;
}

.chart-legend-item {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  font-family: var(--ff-mono);
  color: var(--clr-text-dim);
}

.legend-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}
</style>
</head>
