  const params = { limit: txLimit, offset: txOffset };
  if (tipe) params.tipe = tipe;
  if (from) params.tanggal_mulai = from;
  if (to)   params.tanggal_selesai = to;

  const res = await api('getTransactions', params);
  if (!res.success) {
    wrap.innerHTML = `<div class="loading-center" style="color:var(--clr-red);">❌ ${res.error}</div>`;
    return;
  }

  const txs = res.data.transactions || [];
  txTotal   = res.data.total;

  if (!txs.length) {
    wrap.innerHTML = `<div class="empty-state"><div class="empty-icon">📋</div><p>Belum ada transaksi.</p></div>`;
    document.getElementById('tx-pagination').innerHTML = '';
    return;
  }

  const rows = txs.map(tx => {
    const nomColor = {
      INCOME: 'tx-nominal-positive',
      EXPENSE: 'tx-nominal-negative',
      SAVING: 'tx-nominal-saving',
      WITHDRAWAL: 'tx-nominal-withdraw',
    }[tx.tipe] || '';

    const sign = { INCOME: '+', EXPENSE: '-', SAVING: '▲', WITHDRAWAL: '▼' }[tx.tipe] || '';

    return `<tr>
      <td class="font-mono" style="color:var(--clr-text-muted);font-size:12px">${formatDate(tx.tanggal)}</td>
      <td><span class="tx-type-badge badge-${tx.tipe}">${tx.tipe}</span></td>
      <td>${tx.kategori}</td>
      <td class="${nomColor} font-mono">${sign}${rupiah(tx.nominal)}</td>
      <td style="color:var(--clr-text-dim);font-size:12px">${tx.keterangan || '-'}</td>
      <td>
        <button class="tx-action-btn" onclick="openEditTx(${JSON.stringify(tx).replace(/"/g,'&quot;')})">✏️</button>
        <button class="tx-action-btn del" onclick="confirmDeleteTx('${tx.id}')">🗑️</button>
      </td>
    </tr>`;
  }).join('');

  wrap.innerHTML = `
    <table class="tx-table">
      <thead>
        <tr>
          <th>TANGGAL</th>
          <th>TIPE</th>
          <th>KATEGORI</th>
          <th>NOMINAL</th>
          <th>KETERANGAN</th>
          <th>AKSI</th>
        </tr>
      </thead>
      <tbody>${rows}</tbody>
    </table>`;

  // Pagination
  const totalPages = Math.ceil(txTotal / txLimit);
  const curPage    = Math.floor(txOffset / txLimit) + 1;
  document.getElementById('tx-pagination').innerHTML = `
    <div>Menampilkan ${txOffset + 1}–${Math.min(txOffset + txLimit, txTotal)} dari ${txTotal} transaksi</div>
    <div class="pagination-btns">
      <button class="btn btn-ghost btn-sm" ${curPage === 1 ? 'disabled' : ''} onclick="changePage(-1)">← PREV</button>
      <span style="padding:0 8px;font-family:var(--ff-mono)">${curPage} / ${totalPages || 1}</span>
      <button class="btn btn-ghost btn-sm" ${curPage >= totalPages ? 'disabled' : ''} onclick="changePage(1)">NEXT →</button>
    </div>`;
}

function changePage(dir) {
  txOffset = Math.max(0, txOffset + dir * txLimit);
  loadTransactions(false);
}

document.getElementById('btn-filter-apply').addEventListener('click', () => loadTransactions());
document.getElementById('btn-filter-reset').addEventListener('click', () => {
  document.getElementById('filter-tipe').value = '';
  document.getElementById('filter-from').value = '';
  document.getElementById('filter-to').value   = '';
  loadTransactions();
});

// ── Add Transaction ──────────────────────────────────────────
function openAddTxModal() {
  document.getElementById('modal-tx-title').textContent = 'TAMBAH TRANSAKSI';
  document.getElementById('tx-edit-id').value = '';
  document.getElementById('tx-tanggal').value  = todayISO();
  document.getElementById('tx-tipe').value     = 'SAVING';
  document.getElementById('tx-kategori').value = '';
  document.getElementById('tx-nominal').value  = '';
  document.getElementById('tx-keterangan').value= '';
  document.getElementById('tx-error').style.display = 'none';
  handleTxTipeChange();
  openModal('modal-tx');
}

function openEditTx(tx) {
  document.getElementById('modal-tx-title').textContent = 'EDIT TRANSAKSI';
  document.getElementById('tx-edit-id').value    = tx.id;
  document.getElementById('tx-tanggal').value    = String(tx.tanggal).substring(0,10);
  document.getElementById('tx-tipe').value       = tx.tipe;
  document.getElementById('tx-kategori').value   = tx.kategori;
  document.getElementById('tx-nominal').value    = tx.nominal;
  document.getElementById('tx-keterangan').value = tx.keterangan || '';
  document.getElementById('tx-error').style.display = 'none';
  handleTxTipeChange();
  openModal('modal-tx');
}

document.getElementById('tx-tipe').addEventListener('change', handleTxTipeChange);

function handleTxTipeChange() {
  const tipe  = document.getElementById('tx-tipe').value;
  const group = document.getElementById('tx-target-group');
  if (tipe === 'SAVING' || tipe === 'WITHDRAWAL') {
    group.style.display = 'block';
    document.getElementById('tx-target-id').value = activeTargetId || '';
  } else {
    group.style.display = 'none';
  }
}

document.getElementById('btn-save-tx').addEventListener('click', saveTx);

async function saveTx() {
  const id         = document.getElementById('tx-edit-id').value;
  const tanggal    = document.getElementById('tx-tanggal').value;
  const tipe       = document.getElementById('tx-tipe').value;
  const kategori   = document.getElementById('tx-kategori').value.trim();
  const nominal    = document.getElementById('tx-nominal').value;
  const keterangan = document.getElementById('tx-keterangan').value.trim();
  const target_id  = document.getElementById('tx-target-id').value;
  const errEl      = document.getElementById('tx-error');

  errEl.style.display = 'none';

  if (!tanggal || !tipe || !kategori || !nominal) {
    errEl.textContent = 'Tanggal, tipe, kategori, dan nominal wajib diisi.';
    errEl.style.display = 'block';
    return;
  }

  const spinner = document.getElementById('tx-save-spinner');
  spinner.classList.remove('hidden');
  document.getElementById('btn-save-tx').disabled = true;

  try {
    let res;
    if (id) {
      // Edit
      const data = { id, tanggal, tipe, kategori, nominal: Number(nominal), keterangan };
      if (tipe === 'SAVING' || tipe === 'WITHDRAWAL') data.target_id = target_id;
      res = await api('editTransaction', data);
    } else {
      // Add
      const data = { tanggal, tipe, kategori, nominal: Number(nominal), keterangan };
      if (tipe === 'SAVING' || tipe === 'WITHDRAWAL') data.target_id = target_id;
      res = await api('addTransaction', data);
    }

    if (res.success) {
      closeModal('modal-tx');
      toast('Berhasil!', id ? 'Transaksi diperbarui.' : 'Transaksi ditambahkan.', 'success');

      // Show achievement notifications
      if (res.data && res.data.new_achievements && res.data.new_achievements.length) {
        res.data.new_achievements.forEach(a => {
          setTimeout(() => {
            toast(`🏆 ${a.nama}`, a.deskripsi, 'achievement', a.icon);
          }, 600);
        });
      }

      if (currentPage === 'transactions') loadTransactions();
      if (currentPage === 'dashboard')    loadDashboard();
    } else {
      errEl.textContent = res.error || 'Gagal menyimpan transaksi.';
      errEl.style.display = 'block';
    }
  } catch(e) {
    errEl.textContent = 'Gagal konek ke server.';
    errEl.style.display = 'block';
  } finally {
    spinner.classList.add('hidden');
    document.getElementById('btn-save-tx').disabled = false;
  }
}

// ── Delete Transaction ────────────────────────────────────────
function confirmDeleteTx(id) {
  txDeleteId = id;
  openModal('modal-confirm');
}

document.getElementById('btn-confirm-delete').addEventListener('click', async () => {
  if (!txDeleteId) return;
  const spinner = document.getElementById('del-spinner');
  spinner.classList.remove('hidden');
  document.getElementById('btn-confirm-delete').disabled = true;

  const res = await api('deleteTransaction', { id: txDeleteId });
  spinner.classList.add('hidden');
  document.getElementById('btn-confirm-delete').disabled = false;

  if (res.success) {
    closeModal('modal-confirm');
    toast('Dihapus!', 'Transaksi berhasil dihapus.', 'success');
    loadTransactions();
    txDeleteId = null;
  } else {
    toast('Gagal', res.error, 'error');
  }
});

// ============================================================
//   TARGET
// ============================================================
async function loadTarget() {
  const container = document.getElementById('target-content');
  container.innerHTML = `<div class="loading-center"><div class="spinner"></div> Memuat target...</div>`;

  const res = await api('getTarget');

  if (!res.success) {
    // No active target
    container.innerHTML = buildNoTargetHTML();
    return;
  }

  const t = res.data;
  activeTargetId = t.id;
  const progressW = Math.min(100, t.persen || 0);

  container.innerHTML = `
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;max-width:900px;">

      <div class="card" style="grid-column:span 2;border-color:var(--clr-blue-dim);box-shadow:var(--glow-blue)">
        <div class="card-title">🎯 TARGET AKTIF</div>
        <div class="target-name">${t.nama_target}</div>
        <div class="target-amount">${rupiah(t.total_saving)} <small>/ ${rupiah(t.target_nominal)}</small></div>

        <div class="target-meta-row">
          <div class="target-meta-item"><div class="label">KURANG</div><div class="value" style="color:var(--clr-red)">${rupiah(t.kurang)}</div></div>
          <div class="target-meta-item"><div class="label">PROGRESS</div><div class="value" style="color:var(--clr-blue)">${t.persen}%</div></div>
          <div class="target-meta-item"><div class="label">MULAI</div><div class="value">${formatDate(t.tanggal_mulai)}</div></div>
          <div class="target-meta-item"><div class="label">STATUS</div><div class="value" style="color:var(--clr-green)">${t.status}</div></div>
        </div>

        <div class="progress-wrap">
          <div class="progress-bar-track">
            <div class="progress-bar-fill" id="tg-progress" style="width:0%"></div>
          </div>
        </div>

        <div style="display:flex;gap:12px;margin-top:20px;flex-wrap:wrap;">
          <button class="btn btn-primary btn-sm" id="btn-edit-target">✏️ EDIT TARGET</button>
          <button class="btn btn-sm" style="background:linear-gradient(135deg,var(--clr-green),var(--clr-blue));color:#fff;" id="btn-complete-target">🚀 SELESAIKAN TARGET</button>
        </div>
      </div>

    </div>`;

  setTimeout(() => {
    const fill = document.getElementById('tg-progress');
    if (fill) fill.style.width = progressW + '%';
  }, 100);

  document.getElementById('btn-edit-target').addEventListener('click', () => openTargetModal(t, false));
  document.getElementById('btn-complete-target').addEventListener('click', () => openModal('modal-complete'));
}

function buildNoTargetHTML() {
  return `
    <div class="card" style="max-width:480px;text-align:center;padding:48px 32px;">
      <div style="font-size:64px;margin-bottom:16px">🎯</div>
      <div class="page-title" style="margin-bottom:8px">TIDAK ADA TARGET AKTIF</div>
      <p style="color:var(--clr-text-dim);margin-bottom:24px;font-size:14px">Buat target baru untuk mulai menabung!</p>
      <button class="btn btn-primary" id="btn-new-target">+ BUAT TARGET BARU</button>
    </div>`;
}

function openTargetModal(existing, isCreate) {
  isCreateTarget = isCreate;
  document.getElementById('modal-target-title').textContent = isCreate ? 'BUAT TARGET BARU' : 'EDIT TARGET';
  document.getElementById('target-save-text').textContent   = isCreate ? 'BUAT TARGET' : 'SIMPAN';
  document.getElementById('target-nama').value    = existing ? existing.nama_target    : '';
  document.getElementById('target-nominal').value = existing ? existing.target_nominal : '';
  document.getElementById('target-error').style.display = 'none';
  openModal('modal-target');
}

// Bind new target button (dynamically)
document.getElementById('target-content').addEventListener('click', e => {
  if (e.target.id === 'btn-new-target') openTargetModal(null, true);
});

document.getElementById('btn-save-target').addEventListener('click', async () => {
  const nama    = document.getElementById('target-nama').value.trim();
  const nominal = document.getElementById('target-nominal').value;
  const errEl   = document.getElementById('target-error');
  errEl.style.display = 'none';

  if (!nama || !nominal) {
    errEl.textContent = 'Nama target dan nominal wajib diisi.';
    errEl.style.display = 'block';
    return;
  }

  const spinner = document.getElementById('target-spinner');
  spinner.classList.remove('hidden');
  document.getElementById('btn-save-target').disabled = true;

  let res;
  if (isCreateTarget) {
    res = await api('createTarget', { nama_target: nama, target_nominal: Number(nominal) });
  } else {
    res = await api('updateTarget', { nama_target: nama, target_nominal: Number(nominal) });
  }

  spinner.classList.add('hidden');
  document.getElementById('btn-save-target').disabled = false;

  if (res.success) {
    closeModal('modal-target');
    toast('Berhasil!', isCreateTarget ? 'Target baru dibuat!' : 'Target diperbarui.', 'success');
    loadTarget();
  } else {
    errEl.textContent = res.error;
    errEl.style.display = 'block';
  }
});

// Complete target
document.getElementById('btn-do-complete').addEventListener('click', async () => {
  const spinner = document.getElementById('complete-spinner');
  spinner.classList.remove('hidden');
  document.getElementById('btn-do-complete').disabled = true;

  const res = await api('completeTarget');
  spinner.classList.add('hidden');
  document.getElementById('btn-do-complete').disabled = false;

  if (res.success) {
    closeModal('modal-complete');
    activeTargetId = null;
    toast('🎉 SELAMAT!', res.data.message, 'achievement', '🚀');
    loadTarget();
  } else {
    toast('Gagal', res.error, 'error');
  }
});

// ============================================================
//   ACHIEVEMENTS
// ============================================================
async function loadAchievements() {
  const container = document.getElementById('achievements-content');
  container.innerHTML = `<div class="loading-center"><div class="spinner"></div></div>`;

  const res = await api('getAchievements');
  if (!res.success) {
    container.innerHTML = `<div class="loading-center" style="color:var(--clr-red);">❌ ${res.error}</div>`;
    return;
  }

  const achs = res.data.achievements || [];
  document.getElementById('ach-count-label').textContent =
    `// ${res.data.total_unlocked} / ${res.data.total} achievement terbuka`;

  const cards = achs.map(a => `
    <div class="achievement-card ${a.is_unlocked ? 'unlocked' : 'locked'}">
      <div class="ach-icon">${a.icon}</div>
      <div>
        <div class="ach-name">${a.nama}</div>
        <div class="ach-desc">${a.deskripsi}</div>
        ${a.is_unlocked ? `<div class="ach-date">🔓 ${formatDate(a.tanggal_unlock)}</div>` : '<div class="ach-date" style="color:var(--clr-text-muted)">🔒 Terkunci</div>'}
      </div>
    </div>
  `).join('');

  container.innerHTML = `<div class="achievements-grid">${cards}</div>`;
}

// ============================================================
//   HALL OF FAME
// ============================================================
async function loadHOF() {
  const container = document.getElementById('hof-content');
  container.innerHTML = `<div class="loading-center"><div class="spinner"></div></div>`;

  const res = await api('getHallOfFame');
  if (!res.success) {
    container.innerHTML = `<div class="loading-center" style="color:var(--clr-red);">❌ ${res.error}</div>`;
    return;
  }

  const list = res.data.hall_of_fame || [];
  if (!list.length) {
    container.innerHTML = `<div class="empty-state"><div class="empty-icon">👑</div><p>Belum ada target yang selesai. Semangat!</p></div>`;
    return;
  }

  const rankEmojis = ['🥇','🥈','🥉'];
  const items = list.map((item, i) => `
    <div class="hof-item">
      <div class="hof-rank">${rankEmojis[i] || (i + 1)}</div>
      <div class="hof-info">
        <div class="hof-name">${item.nama_target}</div>
        <div class="hof-meta">${formatDate(item.tanggal_mulai)} → ${formatDate(item.tanggal_selesai)} · ${item.total_hari} hari · ${item.total_saving_tx}x nabung</div>
      </div>
      <div class="hof-amount">${rupiah(item.target_nominal)}</div>
    </div>
  `).join('');

  container.innerHTML = `
    <div class="card-title">👑 DAFTAR TARGET SELESAI</div>
    <div class="hof-list">${items}</div>`;
}

// ============================================================
//   SETTINGS — CHANGE PASSWORD
// ============================================================
document.getElementById('btn-change-pass').addEventListener('click', async () => {
  const oldPass  = document.getElementById('inp-old-pass').value;
  const newPass  = document.getElementById('inp-new-pass').value;
  const confPass = document.getElementById('inp-confirm-pass').value;
  const errEl    = document.getElementById('pass-error');
  errEl.style.display = 'none';

  if (!oldPass || !newPass || !confPass) {
    errEl.textContent = 'Semua field harus diisi.';
    errEl.style.display = 'block';
    return;
  }

  if (newPass !== confPass) {
    errEl.textContent = 'Password baru dan konfirmasi tidak sama.';
    errEl.style.display = 'block';
    return;
  }

  if (newPass.length < 6) {
    errEl.textContent = 'Password baru minimal 6 karakter.';
    errEl.style.display = 'block';
    return;
  }

  try {
    const [oldHash, newHash] = await Promise.all([sha256(oldPass), sha256(newPass)]);
    const res = await api('changePassword', { old_password_hash: oldHash, new_password_hash: newHash });

    if (res.success) {
      toast('Berhasil!', 'Password berhasil diubah.', 'success');
      document.getElementById('inp-old-pass').value   = '';
      document.getElementById('inp-new-pass').value   = '';
      document.getElementById('inp-confirm-pass').value = '';
    } else {
      errEl.textContent = res.error;
      errEl.style.display = 'block';
    }
  } catch(e) {
    errEl.textContent = 'Gagal konek ke server.';
    errEl.style.display = 'block';
  }
});

// ============================================================
