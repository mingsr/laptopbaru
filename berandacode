<script>
// ============================================================
//   CONFIG
// ============================================================
const API_URL = 'https://script.google.com/macros/s/AKfycbx_ZcuQ6PefG-ADyhQrHGYpnb7hlnOTNsBXQfrL_mzerKcYWB05XVUV0xrtFdcNDOU3/exec';

// ============================================================
//   STATE
// ============================================================
let AUTH_TOKEN   = localStorage.getItem('nabung_token') || null;
let currentPage  = 'dashboard';
let txOffset     = 0;
let txLimit      = 20;
let txTotal      = 0;
let txDeleteId   = null;
let activeTargetId = null;
let isCreateTarget = false;

// ============================================================
//   API HELPER
// ============================================================
async function api(action, data = {}, token = AUTH_TOKEN) {
  const body = { action, data };
  if (token) body.token = token;

  const res = await fetch(API_URL, {
    method: 'POST',
    headers: { 'Content-Type': 'text/plain' },
    body: JSON.stringify(body),
  });

  const json = await res.json();
  return json;
}

function sha256(str) {
  // Using SubtleCrypto for secure hashing
  const encoder = new TextEncoder();
  const data     = encoder.encode(str);
  return crypto.subtle.digest('SHA-256', data).then(buf => {
    return Array.from(new Uint8Array(buf))
      .map(b => b.toString(16).padStart(2, '0'))
      .join('');
  });
}

// ============================================================
//   FORMATTERS
// ============================================================
function rupiah(n) {
  const num = Number(n) || 0;
  return 'Rp' + num.toLocaleString('id-ID');
}

function formatDate(str) {
  if (!str || str === 'undefined') return '-';
  const s = String(str).substring(0, 10);
  if (!s || s.length < 10) return '-';
  const [y, m, d] = s.split('-');
  const months = ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des'];
  return `${d} ${months[parseInt(m)-1] || m} ${y}`;
}

function todayISO() {
  const d = new Date();
  return d.toISOString().split('T')[0];
}

// ============================================================
//   TOAST
// ============================================================
function toast(title, msg, type = 'success', icon = null) {
  const container = document.getElementById('toastContainer');
  const icons = { success: '✅', error: '❌', achievement: '🏆', info: 'ℹ️' };
  const el = document.createElement('div');
  el.className = `toast toast-${type}`;
  el.innerHTML = `
    <div class="toast-icon">${icon || icons[type] || '✅'}</div>
    <div class="toast-content">
      <div class="toast-title">${title}</div>
      ${msg ? `<div class="toast-msg">${msg}</div>` : ''}
    </div>
  `;
  container.appendChild(el);
  setTimeout(() => {
    el.classList.add('out');
    setTimeout(() => el.remove(), 300);
  }, 3500);
}

