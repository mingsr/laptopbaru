//   LOGIN
// ============================================================
document.getElementById('btn-login').addEventListener('click', doLogin);
document.getElementById('inp-password').addEventListener('keydown', e => {
  if (e.key === 'Enter') doLogin();
});

async function doLogin() {
  const username = document.getElementById('inp-username').value.trim();
  const password = document.getElementById('inp-password').value;
  const errEl    = document.getElementById('login-error');
  const spinner  = document.getElementById('login-spinner');
  const loginText= document.getElementById('login-text');

  if (!username || !password) {
    errEl.textContent = 'Username dan password wajib diisi.';
    errEl.style.display = 'block';
    return;
  }

  spinner.classList.remove('hidden');
  loginText.textContent = 'AUTENTIKASI...';
  document.getElementById('btn-login').disabled = true;
  errEl.style.display = 'none';

  try {
    const hash = await sha256(password);
    const res  = await api('login', { username, password_hash: hash }, null);

    if (res.success) {
      AUTH_TOKEN = res.data.token;
      localStorage.setItem('nabung_token', AUTH_TOKEN);
      enterApp();
    } else {
      errEl.textContent = res.error || 'Login gagal.';
      errEl.style.display = 'block';
    }
  } catch(e) {
    errEl.textContent = 'Gagal konek ke server. Coba lagi.';
    errEl.style.display = 'block';
  } finally {
    spinner.classList.add('hidden');
    loginText.textContent = 'AKSES SISTEM';
    document.getElementById('btn-login').disabled = false;
  }
}

