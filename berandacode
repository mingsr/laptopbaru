function renderCharts(data7) {
  const canvas = document.getElementById('lineChart');
  if (!canvas) return;

  const ctx    = canvas.getContext('2d');
  const w = canvas.offsetWidth || 600;
  const h = 140;
  canvas.width  = w;
  canvas.height = h;

  if (!data7.length) return;

  const pad  = { top: 12, right: 12, bottom: 28, left: 10 };
  const cw   = w - pad.left - pad.right;
  const ch   = h - pad.top - pad.bottom;

  const allVals = data7.flatMap(d => [d.income, d.expense, d.saving]);
  const maxVal  = Math.max(...allVals, 1);

  function xPos(i) { return pad.left + (i / (data7.length - 1)) * cw; }
  function yPos(v) { return pad.top + ch - (v / maxVal) * ch; }

  function drawLine(key, color) {
    ctx.beginPath();
    ctx.strokeStyle = color;
    ctx.lineWidth   = 2;
    ctx.shadowColor = color;
    ctx.shadowBlur  = 6;
    data7.forEach((d, i) => {
      const x = xPos(i);
      const y = yPos(d[key]);
      if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
    });
    ctx.stroke();
    ctx.shadowBlur = 0;

    // Dots
    data7.forEach((d, i) => {
      ctx.beginPath();
      ctx.arc(xPos(i), yPos(d[key]), 3, 0, Math.PI * 2);
      ctx.fillStyle = color;
      ctx.fill();
    });
  }

  // Grid lines
  ctx.strokeStyle = 'rgba(26,38,68,0.8)';
  ctx.lineWidth   = 1;
  for (let j = 0; j <= 3; j++) {
    const y = pad.top + (ch / 3) * j;
    ctx.beginPath();
    ctx.moveTo(pad.left, y);
    ctx.lineTo(pad.left + cw, y);
    ctx.stroke();
  }

  // Lines
  drawLine('income',  '#00ff88');
  drawLine('expense', '#ff3060');
  drawLine('saving',  '#00d4ff');

  // X labels
  ctx.fillStyle   = '#6278a0';
  ctx.font        = '10px Share Tech Mono, monospace';
  ctx.textAlign   = 'center';
  data7.forEach((d, i) => {
    const label = d.tanggal ? d.tanggal.substring(5) : '';
    ctx.fillText(label, xPos(i), h - 6);
  });
}

function renderCalendar(savingDates) {
  const grid  = document.getElementById('cal-grid');
  if (!grid) return;

  const setDates = new Set(savingDates);
  const today    = todayISO();
  const days     = 90; // show last 90 days

  grid.innerHTML = '';
  for (let i = days - 1; i >= 0; i--) {
    const d = new Date();
    d.setDate(d.getDate() - i);
    const str = d.toISOString().split('T')[0];
    const dot = document.createElement('div');
    dot.className = 'cal-dot';
    if (setDates.has(str)) dot.classList.add('has-saving');
    if (str === today) dot.classList.add('today');
    dot.title = str + (setDates.has(str) ? ' ✓ nabung' : '');
    grid.appendChild(dot);
  }
}

